APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Keep DB_CONNECTION=mongodb for Mongo-first app usage.
DB_CONNECTION=mongodb

# Atlas/local Mongo URI. If password contains @, :, /, ? etc, URL-encode it.
# Example: p@ss:word => p%40ss%3Aword
# DB_URI=mongodb+srv://username:encoded_password@cluster0.xxxxx.mongodb.net/trafficDB?retryWrites=true&w=majority&tls=true
DB_URI=mongodb://127.0.0.1:27017
MONGO_DATABASE=trafficDB

# Optional Mongo connection tuning (Atlas/network reliability)
MONGO_TLS=true
MONGO_RETRY_WRITES=true
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_CONNECT_TIMEOUT_MS=10000
MONGO_SOCKET_TIMEOUT_MS=10000

# Test-only Mongo settings (use local Mongo to avoid Atlas dependency in tests)
MONGO_USER_CONNECTION=mongodb
TEST_DB_URI=mongodb://127.0.0.1:27017/?directConnection=true&serverSelectionTimeoutMS=2000&connectTimeoutMS=2000
TEST_MONGO_DATABASE=traffic_test
MONGO_TESTS_REQUIRE_CONNECTION=false

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Gmail SMTP (use a Google "App Password", not your normal password)
# Recommended for Gmail:
# - 587 + smtp (STARTTLS)
# Alternative:
# - 465 + smtps (implicit TLS)
MAIL_MAILER=smtp
MAIL_SCHEME=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_gmail_address@gmail.com
MAIL_PASSWORD=your_gmail_app_password
MAIL_FROM_ADDRESS=your_gmail_address@gmail.com
MAIL_FROM_NAME="${APP_NAME}"

# Optional: use a specific SQL connection for password reset tokens.
# Keep empty to use default DB connection.
AUTH_PASSWORD_RESET_CONNECTION=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
