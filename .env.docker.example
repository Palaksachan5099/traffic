# -----------------------------------------------------------------------------
# Docker deployment environment
# -----------------------------------------------------------------------------
# 1. Copy this file:  cp .env.docker.example .env.docker
# 2. Set APP_KEY (generate: php artisan key:generate --show)
# 3. Start stack:     docker compose --env-file .env.docker up -d --build
# -----------------------------------------------------------------------------

APP_NAME=Traffic
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_STACK=single
LOG_LEVEL=info

# MongoDB (service name "mongodb" from docker-compose.yml)
DB_CONNECTION=mongodb
DB_URI=mongodb://mongodb:27017
MONGO_DATABASE=trafficDB

MONGO_TLS=false
MONGO_RETRY_WRITES=true
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_CONNECT_TIMEOUT_MS=10000
MONGO_SOCKET_TIMEOUT_MS=10000

MONGO_USER_CONNECTION=mongodb

# Sessions / cache (file driver works inside container)
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

# Docker Compose ports (used by docker compose --env-file .env.docker)
APP_PORT=8000
MONGO_PORT=27017

# Mail (optional — set for production notifications)
MAIL_MAILER=smtp
MAIL_SCHEME=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
